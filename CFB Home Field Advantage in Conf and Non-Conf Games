# I wanted to measure how much of a difference Home Field Advantage was for in Conference and out of Conference Games. 
# So I filtered my search to get the win rate for both examples.

cfbd_games |> filter(neutral_site==FALSE, !is.na(home_points), !is.na(away_points), home_division=="fbs") |>
  mutate(home_win=home_points>away_points) |> 
  group_by(conference_game) |> 
  summarize(home_win_rate= mean(home_win, na.rm=TRUE), total_games = n(), .groups= "drop")
# A tibble: 2 × 3
conference_game home_win_rate total_games
