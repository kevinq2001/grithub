install.packages("nflfastR")
library(nflfastR)

## Jets avg EPA per Down##
nyj.epa <- pbp 
  |> filter(posteam=="NYJ", play_type=="run" | play_type== "pass", !is.na(down)
   ) |> group_by(posteam, down, play_type 
   ) |> summarize (avgepa=mean(epa))
nyj.epa |>
  gt() |>
  tab_header(
    title = "2023 NYJ EPA by Down",
    subtitle = "Grouped by Play Type"
  ) |>
  cols_label(
    play_type = "Down",
    avgepa = "Avg EPA"
  ) |>
  fmt_number(columns = avgepa, decimals = 3) |>
  data_color(columns = avgepa, palette = "RdYlGn")
  ) |>
  gtsave( "nyj_epa_chart.png")
