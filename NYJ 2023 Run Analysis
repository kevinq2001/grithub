## NFL Run Pct by Down##
nfl.run.pct <- pbp 
  |> filter(play_type=="run" |play_type=="pass", !is.na(down)
  ) |> group_by(down
  ) |> summarize(total_plays=n(), total_runs= sum(play_type=="run"), run_pct= (total_runs/total_plays))
nfl.run.pct |>
  gt() |>
  tab_header(
    title = "2023 NFL Rush Percentage by Down",
    subtitle = "Grouped by Play Type"
  ) |>
  cols_label(
    down = "Down",
    run_pct = "Run Pct", total_plays="Total Plays", total_runs="Total Runs"
  ) |>
  gtsave( "nfl_run_pct.png")


